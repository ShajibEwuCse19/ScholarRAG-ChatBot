storage/uploaded_papers/*
!storage/uploaded_papers/.gitkeep

# Generated outputs
outputs/results/*
!outputs/results/.gitkeep
outputs/screenshots/*
!outputs/screenshots/.gitkeep
outputs/logs/*
!outputs/logs/.gitkeep

